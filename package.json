{
  "name": "meridian",
  "version": "0.1.0",
  "private": true,
  "description": "Production RAG System",
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "build": "pnpm run --filter=@meridian/* build",
    "lint": "pnpm run --parallel lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "pnpm run --parallel typecheck",
    "prepare": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit"
  },
  "devDependencies": {
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
